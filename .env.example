# LLM (xAI Grok)
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.3

# Express backend the agent calls (reuse your existing server)
EXPRESS_BASE_URL=http://localhost:3000

# MongoDB for conversation memory (can be the SAME cluster as your app)
MONGODB_URI=mongodb://localhost:27017
CHECKPOINT_DB=agent_memory

# Frontend origin(s), comma-separated
CORS_ORIGINS=http://localhost:5173
